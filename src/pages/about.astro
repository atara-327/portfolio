---
import BaseLayouts from "@/Layouts/BaseLayouts.astro";

const birthDay = new Date(2005, 2, 27);
const age = Math.floor((new Date().getTime() - birthDay.getTime()) / (1000 * 60 * 60 * 24 * 365.25));
---

<BaseLayouts>
  <div class="mx-auto max-w-2xl py-8">
    <h1 class="mb-8 text-3xl font-bold text-purple-400">About Me</h1>

    <div
      class="bg-base-200/30 border-base-200 rounded-2xl border p-8 shadow-lg shadow-purple-900/5"
    >
      <h2 class="text-base-content mb-4 text-2xl font-semibold">atara</h2>
      <p class="text-base-content/80 mb-8 text-lg leading-relaxed">
        システムエンジニアです。{age}歳です。<br />
        主にWebアプリの開発をしています。新しい技術を学ぶのが好きで、フロントエンド・バックエンド・インフラなど、幅広い技術を薄く触っています。
      </p>

      <h3 class="mb-4 text-lg font-semibold text-purple-300">Skills & Tools</h3>
      <div class="flex flex-wrap gap-2.5">
        {
          [
            "HTML/CSS",
            "JavaScript",
            "TypeScript",
            "React",
            "Vue.js",
            "Astro",
            "Tailwind CSS",
            "Python",
            "Django",
            "Java",
            "Spring",
            "Docker",
          ].map((skill) => (
            <span class="badge badge-outline border-purple-500/30 px-4 py-3 text-purple-400/90 shadow-sm">
              {skill}
            </span>
          ))
        }
      </div>
      <h3 class="mt-8 mb-4 text-lg font-semibold text-purple-300">Links</h3>
      <ul class="flex flex-col gap-2.5 ps-4">
        <il
          >GitHub： <a
            class="link"
            href="https://github.com/atara-327"
            target="_blank">atara-327</a
          ></il
        >
        <il
          >X： <a class="link" href="https://x.com/atara_0327" target="_blank"
            >atara_0327</a
          ></il
        >
        <il
          >Qiita： <a
            class="link"
            href="https://qiita.com/atara0327"
            target="_blank">atara0327</a
          ></il
        >
        <il>Discord： <span class="">atara.com</span></il>
      </ul>
    </div>
  </div>
</BaseLayouts>
