---
import { getCollection } from "astro:content";
import BaseLayouts from "@/Layouts/BaseLayouts.astro";
import "@/styles/md.css";

export async function getStaticPaths() {
  const works = await getCollection("works");
  return works.map((work) => ({
    params: { slug: work.slug },
    props: { work },
  }));
}

const { work } = Astro.props;
const { Content } = await work.render();
---

<BaseLayouts>
  <article class="mx-auto max-w-4xl py-8">
    <div class="mb-8">
      <a
        href="/"
        class="btn btn-outline border-purple-500/50 text-purple-400 shadow-sm transition-all hover:border-purple-500 hover:bg-purple-500 hover:text-white"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="2"
          stroke="currentColor"
          class="mr-1 h-5 w-5"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"></path>
        </svg>
        作品一覧へ戻る
      </a>
    </div>

    <div class="mb-12 text-center">
      <h1
        class="text-base-content mb-4 text-4xl font-extrabold tracking-tight md:text-5xl"
      >
        {work.data.title}
      </h1>

      {
        work.data.year && (
          <div class="mb-6">
            <span class="badge badge-lg badge-outline border-purple-500/30 text-purple-400/80">
              {work.data.year}
            </span>
          </div>
        )
      }

      <div class="flex flex-wrap items-center justify-center gap-2">
        {
          work.data.tags.map((tag) => (
            <span class="badge badge-lg badge-outline border-purple-500/30 text-purple-400/80">
              {tag}
            </span>
          ))
        }
      </div>
    </div>

    {
      work.data.thumbnail && (
        <div class="border-base-200 bg-base-300/30 mb-16 flex max-h-125 justify-center overflow-hidden rounded-2xl border shadow-2xl shadow-purple-900/10">
          <img
            src={work.data.thumbnail}
            alt={`${work.data.title} thumbnail`}
            class="h-auto w-full object-cover"
          />
        </div>
      )
    }

    <div
      class="works-md-content prose prose-invert lg:prose-lg prose-purple prose-p:text-base-content/80 prose-headings:text-base-content prose-headings:font-bold prose-a:text-purple-400 hover:prose-a:text-purple-300 hover:prose-a:underline prose-strong:text-purple-300 bg-base-200/10 border-base-200/50 prose-ul:my-6 prose-li:my-2 max-w-none rounded-2xl border p-8 leading-relaxed shadow-sm marker:text-purple-400 md:p-12"
    >
      <Content />
    </div>
  </article>
</BaseLayouts>
