---
import { getCollection } from "astro:content";
import BaseLayouts from "@/Layouts/BaseLayouts.astro";
import WorkCard from "@/components/WorkCard.astro";

const works = (await getCollection("works"))
  .filter((work) => work.data.isPublished)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayouts>
  <div class="mt-8 mb-16 flex flex-col items-center text-center">
    <h1
      class="mb-8 bg-linear-to-br from-purple-400 to-purple-700 bg-clip-text text-4xl font-extrabold tracking-tight text-transparent md:text-5xl"
    >
      Atara's Portfolio
    </h1>
    <p
      class="text-base-content/80 mx-auto mb-8 max-w-2xl text-lg leading-relaxed"
    >
      これまでに制作したアプリケーションやプロジェクトをまとめたポートフォリオサイトです。<br
      />みていってね～。
    </p>
    <a
      href="/about"
      class="btn btn-primary rounded-full border-none bg-purple-600 px-8 text-white shadow-lg shadow-purple-900/20 hover:bg-purple-500"
    >
      About Me
    </a>
  </div>
  <hr class="mb-8 border-slate-700" />

  <div class="grid grid-cols-1 gap-x-10 gap-y-6 md:grid-cols-2">
    {works.map((work) => <WorkCard work={work} />)}
  </div>
</BaseLayouts>
