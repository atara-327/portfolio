---
import type { CollectionEntry } from "astro:content";

interface Props {
  work: CollectionEntry<"works">;
}

const { work } = Astro.props;
---

<a
  href={`/works/${work.slug}`}
  class="card bg-base-100 hover:bg-base-200 border-base-200/50 group overflow-hidden border transition-all duration-300 hover:border-purple-500/50 hover:shadow-lg hover:shadow-purple-900/20"
>
  {
    work.data.thumbnail && (
      <figure class="bg-base-300/30 h-48 overflow-hidden">
        <img
          src={work.data.thumbnail}
          alt={work.data.title}
          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
        />
      </figure>
    )
  }
  <div class="card-body">
    <div class="mb-2 flex items-start justify-between gap-4">
      <h2
        class="card-title text-xl font-bold transition-colors group-hover:text-purple-400"
      >
        {work.data.title}
      </h2>
      {
        work.data.date && (
          <span class="badge badge-outline shrink-0 border-purple-500/30 text-xs text-purple-400/80">
            {new Date(work.data.date).getFullYear()}
          </span>
        )
      }
    </div>

    <div class="mt-auto flex flex-wrap gap-2">
      {
        work.data.tags.map((tag) => (
          <span class="badge badge-sm badge-ghost bg-base-200/50 border-base-300 text-xs">
            {tag}
          </span>
        ))
      }
    </div>
  </div>
</a>
