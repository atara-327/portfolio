---
import "@/styles/global.css";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
---

<html lang="ja" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Atara's Portfolio</title>
  </head>
  <body
    class="bg-base-100 text-base-content flex min-h-screen flex-col font-sans antialiased selection:bg-purple-500/30 selection:text-purple-100"
  >
    <Header />
    <main class="container mx-auto max-w-4xl grow px-4 py-12">
      <slot />
    </main>
    <Footer />
  </body>
</html>
